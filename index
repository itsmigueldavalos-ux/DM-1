<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Demora Pick Zones — LIVE</title>
  <style>
    :root{
      --bg:#0b1020;
      --panel:#0f1730;
      --panel2:#0c1328;
      --text:rgba(255,255,255,.92);
      --muted:rgba(255,255,255,.65);
      --border:rgba(255,255,255,.12);
      --shadow:0 10px 25px rgba(0,0,0,.35);

      /* Status colors (TV-safe, high contrast) */
      --closed:#e11d48;     /* red */
      --ws:#f59e0b;         /* amber */
      --empty:#fb923c;      /* orange */
      --picks:#22c55e;      /* green */
      --neutral:#64748b;    /* slate */
      --focus:#38bdf8;      /* cyan */
    }

    *{box-sizing:border-box}
    body{
      margin:0;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial;
      background: radial-gradient(1200px 800px at 20% 10%, #182257 0%, var(--bg) 50%, #070a14 100%);
      color:var(--text);
      height:100vh;
      overflow:hidden;
    }

    .wrap{
      height:100vh;
      display:grid;
      grid-template-rows:auto 1fr auto;
      gap:14px;
      padding:16px;
    }

    header{
      display:flex;
      align-items:flex-end;
      justify-content:space-between;
      gap:16px;
    }
    .title{
      display:flex;
      flex-direction:column;
      gap:6px;
    }
    .title h1{
      margin:0;
      font-size:34px;
      letter-spacing:.5px;
      font-weight:850;
    }
    .title .sub{
      color:var(--muted);
      font-size:14px;
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      align-items:center;
    }
    .pill{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:6px 10px;
      border:1px solid var(--border);
      border-radius:999px;
      background:rgba(255,255,255,.04);
    }
    .dot{
      width:8px;height:8px;border-radius:50%;
      background:var(--focus);
      box-shadow:0 0 0 6px rgba(56,189,248,.12);
    }

    .grid{
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap:14px;
      height:100%;
      min-height:0;
    }

    .card{
      background:linear-gradient(180deg, rgba(255,255,255,.06) 0%, rgba(255,255,255,.03) 100%);
      border:1px solid var(--border);
      box-shadow: var(--shadow);
      border-radius:18px;
      padding:14px;
      display:grid;
      grid-template-rows:auto auto 1fr auto;
      gap:12px;
      min-height:0;
    }

    .cardTop{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
    }
    .cardTitle{
      display:flex;
      align-items:baseline;
      gap:10px;
      flex-wrap:wrap;
    }
    .cardTitle .name{
      font-size:26px;
      font-weight:850;
      letter-spacing:.2px;
      margin:0;
    }
    .cardTitle .dir{
      font-size:20px;
      font-weight:900;
      color:rgba(255,255,255,.85);
    }
    .badge{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:6px 10px;
      border-radius:999px;
      border:1px solid var(--border);
      background:rgba(0,0,0,.18);
      font-weight:700;
      font-size:13px;
      color:rgba(255,255,255,.88);
      white-space:nowrap;
    }
    .badge .miniDot{
      width:10px;height:10px;border-radius:3px;
      background:var(--neutral);
    }

    .lane{
      background:rgba(0,0,0,.16);
      border:1px solid var(--border);
      border-radius:16px;
      padding:12px;
      display:grid;
      grid-template-rows:auto 1fr;
      gap:10px;
      min-height:0;
    }

    .zones{
      display:grid;
      gap:10px;
      align-items:stretch;
    }
    /* Horizontal 4-step layout */
    .zones.horizontal{
      grid-template-columns: repeat(4, 1fr);
    }

    .zone{
      border-radius:14px;
      padding:12px;
      border:1px solid var(--border);
      background:rgba(255,255,255,.04);
      display:flex;
      flex-direction:column;
      justify-content:space-between;
      min-height:110px;
      position:relative;
      overflow:hidden;
    }
    .zone .label{
      font-size:15px;
      font-weight:900;
      letter-spacing:.4px;
      opacity:.95;
    }
    .zone .arrow{
      font-size:34px;
      font-weight:950;
      line-height:1;
      opacity:.55;
      align-self:flex-end;
    }

    .zone.active{
      border-color: rgba(56,189,248,.55);
      box-shadow: 0 0 0 3px rgba(56,189,248,.12) inset;
    }
    .zone.active::after{
      content:"LIVE";
      position:absolute;
      top:10px;
      right:10px;
      padding:6px 10px;
      border-radius:999px;
      background:rgba(56,189,248,.18);
      border:1px solid rgba(56,189,248,.5);
      color:#d9f3ff;
      font-weight:950;
      font-size:12px;
      letter-spacing:.8px;
    }

    /* Zone color “wash” */
    .zone.closed{ background: linear-gradient(180deg, rgba(225,29,72,.22), rgba(255,255,255,.03)); }
    .zone.ws{     background: linear-gradient(180deg, rgba(245,158,11,.22), rgba(255,255,255,.03)); }
    .zone.empty{  background: linear-gradient(180deg, rgba(251,146,60,.22), rgba(255,255,255,.03)); }
    .zone.picks{  background: linear-gradient(180deg, rgba(34,197,94,.22), rgba(255,255,255,.03)); }

    .controls{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      justify-content:flex-end;
    }
    .btn{
      cursor:pointer;
      border:1px solid var(--border);
      background:rgba(255,255,255,.05);
      color:var(--text);
      padding:10px 12px;
      border-radius:12px;
      font-weight:850;
      font-size:13px;
      letter-spacing:.2px;
      transition:transform .05s ease, background .2s ease;
      user-select:none;
    }
    .btn:hover{ background:rgba(255,255,255,.08); }
    .btn:active{ transform: translateY(1px); }
    .btn.primary{
      border-color: rgba(56,189,248,.55);
      background: rgba(56,189,248,.12);
    }
    .btn.danger{
      border-color: rgba(225,29,72,.45);
      background: rgba(225,29,72,.12);
    }

    footer{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      color:var(--muted);
      font-size:13px;
      border-top:1px solid rgba(255,255,255,.08);
      padding-top:10px;
    }

    .legend{
      display:flex;
      gap:12px;
      flex-wrap:wrap;
      align-items:center;
    }
    .key{
      display:flex;
      align-items:center;
      gap:8px;
      padding:6px 10px;
      border:1px solid var(--border);
      border-radius:999px;
      background:rgba(255,255,255,.03);
      white-space:nowrap;
    }
    .swatch{
      width:12px;height:12px;border-radius:4px;
    }

    /* TV scaling */
    @media (max-width: 1100px){
      .grid{ grid-template-columns:1fr; }
      .zones.horizontal{ grid-template-columns:1fr 1fr; }
      .zone{ min-height:90px; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <header>
      <div class="title">
        <h1>DEMORA PICK ZONES — LIVE</h1>
        <div class="sub">
          <span class="pill"><span class="dot"></span><span id="clock">--:--:--</span></span>
          <span class="pill">Last Update: <strong id="lastUpdate">—</strong></span>
          <span class="pill">Mode: <strong>TV</strong></span>
        </div>
      </div>

      <div class="controls">
        <button class="btn primary" id="btnSync">Sync Screens</button>
        <button class="btn" id="btnResetDM1">Reset DM1</button>
        <button class="btn" id="btnResetDM2">Reset DM2</button>
        <button class="btn danger" id="btnFactory">Factory Reset</button>
      </div>
    </header>

    <main class="grid">
      <!-- DM 1 -->
      <section class="card" data-dm="dm1">
        <div class="cardTop">
          <div class="cardTitle">
            <h2 class="name">DM 1</h2>
            <div class="dir">← West 1</div>
          </div>
          <div class="badge" id="badgeDM1">
            <span class="miniDot" id="dotDM1"></span>
            <span id="statusTextDM1">—</span>
          </div>
        </div>

        <div class="lane">
          <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;">
            <div style="font-weight:900;letter-spacing:.3px;color:rgba(255,255,255,.88)">
              Flow: Closed Zone → WaterSpider → Empty → Picks Loading Zone
            </div>
            <div style="color:var(--muted);font-weight:700">Direction: <strong>LEFT</strong></div>
          </div>

          <div class="zones horizontal" id="zonesDM1">
            <div class="zone closed" data-zone="closed"><div class="label">CLOSED ZONE</div><div class="arrow">←</div></div>
            <div class="zone ws"     data-zone="ws"><div class="label">WATERSPIDER</div><div class="arrow">←</div></div>
            <div class="zone empty"  data-zone="empty"><div class="label">EMPTY</div><div class="arrow">←</div></div>
            <div class="zone picks"  data-zone="picks"><div class="label">PICKS LOADING</div><div class="arrow">←</div></div>
          </div>
        </div>

        <div class="controls" style="justify-content:flex-start;">
          <button class="btn" data-action="set" data-dm="dm1" data-zone="closed">Set CLOSED</button>
          <button class="btn" data-action="set" data-dm="dm1" data-zone="ws">Set WATERSPIDER</button>
          <button class="btn" data-action="set" data-dm="dm1" data-zone="empty">Set EMPTY</button>
          <button class="btn" data-action="set" data-dm="dm1" data-zone="picks">Set PICKS LOADING</button>
        </div>
      </section>

      <!-- DM 2 -->
      <section class="card" data-dm="dm2">
        <div class="cardTop">
          <div class="cardTitle">
            <h2 class="name">DM 2</h2>
            <div class="dir">→ West 2</div>
          </div>
          <div class="badge" id="badgeDM2">
            <span class="miniDot" id="dotDM2"></span>
            <span id="statusTextDM2">—</span>
          </div>
        </div>

        <div class="lane">
          <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;">
            <div style="font-weight:900;letter-spacing:.3px;color:rgba(255,255,255,.88)">
              Flow: Closed Zone → WaterSpider → Empty → Picks Loading Zone
            </div>
            <div style="color:var(--muted);font-weight:700">Direction: <strong>RIGHT</strong></div>
          </div>

          <div class="zones horizontal" id="zonesDM2">
            <div class="zone closed" data-zone="closed"><div class="label">CLOSED ZONE</div><div class="arrow">→</div></div>
            <div class="zone ws"     data-zone="ws"><div class="label">WATERSPIDER</div><div class="arrow">→</div></div>
            <div class="zone empty"  data-zone="empty"><div class="label">EMPTY</div><div class="arrow">→</div></div>
            <div class="zone picks"  data-zone="picks"><div class="label">PICKS LOADING</div><div class="arrow">→</div></div>
          </div>
        </div>

        <div class="controls" style="justify-content:flex-start;">
          <button class="btn" data-action="set" data-dm="dm2" data-zone="closed">Set CLOSED</button>
          <button class="btn" data-action="set" data-dm="dm2" data-zone="ws">Set WATERSPIDER</button>
          <button class="btn" data-action="set" data-dm="dm2" data-zone="empty">Set EMPTY</button>
          <button class="btn" data-action="set" data-dm="dm2" data-zone="picks">Set PICKS LOADING</button>
        </div>
      </section>
    </main>

    <footer>
      <div class="legend">
        <span class="key"><span class="swatch" style="background:var(--closed)"></span>Closed</span>
        <span class="key"><span class="swatch" style="background:var(--ws)"></span>WaterSpider</span>
        <span class="key"><span class="swatch" style="background:var(--empty)"></span>Empty</span>
        <span class="key"><span class="swatch" style="background:var(--picks)"></span>Picks Loading</span>
      </div>
      <div>
        Tip: Open this file on multiple screens — click <strong>Sync Screens</strong> to auto-update across tabs.
      </div>
    </footer>
  </div>

  <script>
    // ---------- LIVE DATA MODEL ----------
    const STORAGE_KEY = "demora_pick_zones_live_v1";
    const defaultState = {
      dm1: "closed",
      dm2: "closed",
      lastUpdate: null
    };

    const ZONE_META = {
      closed: { label: "CLOSED ZONE", colorVar: "--closed" },
      ws:     { label: "WATERSPIDER", colorVar: "--ws" },
      empty:  { label: "EMPTY", colorVar: "--empty" },
      picks:  { label: "PICKS LOADING", colorVar: "--picks" },
    };

    function nowStamp(){
      const d = new Date();
      return d.toLocaleString([], { year:"numeric", month:"2-digit", day:"2-digit", hour:"2-digit", minute:"2-digit", second:"2-digit" });
    }

    function loadState(){
      try{
        const raw = localStorage.getItem(STORAGE_KEY);
        if(!raw) return { ...defaultState };
        const parsed = JSON.parse(raw);
        return { ...defaultState, ...parsed };
      }catch{
        return { ...defaultState };
      }
    }

    function saveState(state){
      localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
      // Broadcast to other tabs/screens instantly
      window.dispatchEvent(new Event("storage-sync-local"));
    }

    let state = loadState();

    // ---------- UI RENDER ----------
    function setBadge(dm, zoneKey){
      const meta = ZONE_META[zoneKey] || { label:"—", colorVar:"--neutral" };
      const textEl = document.getElementById(dm === "dm1" ? "statusTextDM1" : "statusTextDM2");
      const dotEl  = document.getElementById(dm === "dm1" ? "dotDM1" : "dotDM2");

      textEl.textContent = meta.label;
      dotEl.style.background = getComputedStyle(document.documentElement).getPropertyValue(meta.colorVar).trim() || "#64748b";
    }

    function setActiveZone(dm, zoneKey){
      const zonesWrap = document.getElementById(dm === "dm1" ? "zonesDM1" : "zonesDM2");
      zonesWrap.querySelectorAll(".zone").forEach(z => {
        z.classList.toggle("active", z.dataset.zone === zoneKey);
      });
    }

    function render(){
      setBadge("dm1", state.dm1);
      setBadge("dm2", state.dm2);
      setActiveZone("dm1", state.dm1);
      setActiveZone("dm2", state.dm2);
      document.getElementById("lastUpdate").textContent = state.lastUpdate || "—";
    }

    // ---------- ACTIONS ----------
    function setZone(dm, zoneKey){
      state = { ...state, [dm]: zoneKey, lastUpdate: nowStamp() };
      saveState(state);
      render();
    }

    function resetDM(dm){
      setZone(dm, "closed");
    }

    function factoryReset(){
      state = { ...defaultState, lastUpdate: nowStamp() };
      saveState(state);
      render();
    }

    // Click handlers for buttons
    document.querySelectorAll("button[data-action='set']").forEach(btn => {
      btn.addEventListener("click", () => {
        setZone(btn.dataset.dm, btn.dataset.zone);
      });
    });

    document.getElementById("btnResetDM1").addEventListener("click", () => resetDM("dm1"));
    document.getElementById("btnResetDM2").addEventListener("click", () => resetDM("dm2"));
    document.getElementById("btnFactory").addEventListener("click", factoryReset);

    // Sync across multiple screens:
    // 1) Works across tabs on same machine via 'storage' events
    // 2) Also triggers a local event for same-tab updates (some kiosk setups block storage events)
    document.getElementById("btnSync").addEventListener("click", () => {
      // Force a save to trigger storage event
      saveState({ ...state, lastUpdate: state.lastUpdate || nowStamp() });
      render();
    });

    window.addEventListener("storage", (e) => {
      if(e.key === STORAGE_KEY){
        state = loadState();
        render();
      }
    });

    window.addEventListener("storage-sync-local", () => {
      state = loadState();
      render();
    });

    // Clock
    function tickClock(){
      const d = new Date();
      document.getElementById("clock").textContent = d.toLocaleTimeString([], { hour:"2-digit", minute:"2-digit", second:"2-digit" });
    }
    setInterval(tickClock, 250);
    tickClock();

    // First render
    render();
  </script>
</body>
</html>
