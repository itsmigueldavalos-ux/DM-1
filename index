<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DM 1 (West Zone) - LIVE Status Board</title>

    <!-- React 18 + Babel -->
    <script crossorigin src="https://unpkg.com/react@18/umd/react.development.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

    <style>
      :root{
        --bg:#0b1020;
        --card:#111a33;
        --muted:rgba(255,255,255,.7);
        --text:rgba(255,255,255,.92);
        --border:rgba(255,255,255,.12);
        --shadow:0 12px 28px rgba(0,0,0,.35);

        --closed:#6b7280;
        --water:#f59e0b;
        --empty:#22c55e;
        --picks:#3b82f6;
      }
      *{box-sizing:border-box}
      body{
        margin:0;
        font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial;
        background:radial-gradient(1200px 700px at 20% 0%, #1b2a6b 0%, rgba(27,42,107,0) 60%),
                   radial-gradient(900px 600px at 90% 10%, #7c2d12 0%, rgba(124,45,18,0) 55%),
                   var(--bg);
        color:var(--text);
      }
      .wrap{
        max-width:1200px;
        margin:28px auto;
        padding:0 16px 28px;
      }
      .topbar{
        display:flex;
        gap:14px;
        flex-wrap:wrap;
        align-items:flex-end;
        justify-content:space-between;
        margin-bottom:14px;
      }
      .title{
        display:flex;
        flex-direction:column;
        gap:6px;
      }
      h1{
        font-size:22px;
        margin:0;
        letter-spacing:.2px;
      }
      .sub{
        font-size:13px;
        color:var(--muted);
        display:flex;
        gap:10px;
        flex-wrap:wrap;
        align-items:center;
      }
      .pill{
        display:inline-flex;
        align-items:center;
        gap:8px;
        padding:6px 10px;
        border:1px solid var(--border);
        border-radius:999px;
        background:rgba(255,255,255,.06);
      }
      .dot{
        width:8px;height:8px;border-radius:999px;
        background:#22c55e;
        box-shadow:0 0 0 4px rgba(34,197,94,.18);
      }
      .controls{
        display:flex;
        gap:10px;
        flex-wrap:wrap;
        align-items:flex-end;
      }
      .control{
        background:rgba(255,255,255,.06);
        border:1px solid var(--border);
        border-radius:14px;
        padding:10px 12px;
        box-shadow:var(--shadow);
        min-width:220px;
      }
      .control label{
        display:block;
        font-size:12px;
        color:var(--muted);
        margin-bottom:6px;
      }
      .control input{
        width:100%;
        padding:10px 10px;
        border-radius:10px;
        border:1px solid rgba(255,255,255,.18);
        background:rgba(0,0,0,.25);
        color:var(--text);
        outline:none;
      }
      .row{
        display:flex;
        gap:12px;
        flex-wrap:wrap;
      }
      .btn{
        padding:10px 12px;
        border-radius:12px;
        border:1px solid var(--border);
        background:rgba(255,255,255,.06);
        color:var(--text);
        cursor:pointer;
      }
      .btn:hover{background:rgba(255,255,255,.10)}
      .grid{
        display:grid;
        grid-template-columns:repeat(4, minmax(220px, 1fr));
        gap:14px;
        margin-top:14px;
      }
      @media (max-width:1050px){
        .grid{grid-template-columns:repeat(2, minmax(220px, 1fr));}
      }
      @media (max-width:540px){
        .grid{grid-template-columns:1fr;}
      }
      .col{
        background:rgba(255,255,255,.04);
        border:1px solid var(--border);
        border-radius:18px;
        box-shadow:var(--shadow);
        overflow:hidden;
      }
      .colHead{
        display:flex;
        justify-content:space-between;
        align-items:center;
        padding:12px 12px;
        border-bottom:1px solid var(--border);
        background:rgba(0,0,0,.18);
      }
      .colTitle{
        display:flex;
        align-items:center;
        gap:10px;
        font-weight:700;
        font-size:13px;
        letter-spacing:.2px;
      }
      .badge{
        font-size:12px;
        padding:4px 8px;
        border-radius:999px;
        border:1px solid rgba(255,255,255,.16);
        color:rgba(255,255,255,.86);
      }
      .list{
        padding:10px;
        display:flex;
        flex-direction:column;
        gap:10px;
        min-height:120px;
      }
      .card{
        border:1px solid rgba(255,255,255,.14);
        background:linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.03));
        border-radius:16px;
        padding:10px 10px;
        display:flex;
        flex-direction:column;
        gap:10px;
      }
      .cardTop{
        display:flex;
        justify-content:space-between;
        gap:10px;
        align-items:flex-start;
      }
      .zoneName{
        font-weight:800;
        font-size:14px;
      }
      .mini{
        font-size:12px;
        color:var(--muted);
      }
      .statusChip{
        font-size:12px;
        padding:6px 10px;
        border-radius:999px;
        border:1px solid rgba(255,255,255,.18);
        display:inline-flex;
        align-items:center;
        gap:8px;
        white-space:nowrap;
      }
      .statusDot{width:10px;height:10px;border-radius:999px}
      .fields{
        display:grid;
        grid-template-columns: 1fr 1fr;
        gap:10px;
      }
      .field label{
        display:block;
        font-size:11px;
        color:var(--muted);
        margin-bottom:6px;
      }
      .field input, .field select{
        width:100%;
        padding:9px 10px;
        border-radius:12px;
        border:1px solid rgba(255,255,255,.18);
        background:rgba(0,0,0,.25);
        color:var(--text);
        outline:none;
      }
      .switchRow{
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap:12px;
        margin-top:2px;
      }
      .switchRow .hint{font-size:12px;color:var(--muted)}
      .toggle{
        width:54px;height:30px;border-radius:999px;
        border:1px solid rgba(255,255,255,.18);
        background:rgba(0,0,0,.25);
        position:relative;
        cursor:pointer;
        flex:0 0 auto;
      }
      .knob{
        width:24px;height:24px;border-radius:999px;
        background:rgba(255,255,255,.88);
        position:absolute;
        top:50%; transform:translateY(-50%);
        left:3px;
        transition:left .18s ease;
      }
      .toggle.on{background:rgba(34,197,94,.18); border-color:rgba(34,197,94,.35)}
      .toggle.on .knob{left:27px;}
      .foot{
        margin-top:14px;
        font-size:12px;
        color:var(--muted);
        line-height:1.45;
      }
      .mono{font-family:ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;}
    </style>
  </head>

  <body>
    <div id="root"></div>

    <script type="text/babel">
      const STORAGE_KEY = "dm1_west_live_board_v1";
      const CHANNEL = "dm1_west_live_board_channel";

      const DEFAULT_ZONES = [
        { id: "WZ-A", name: "West Zone A", pallets: 0, closed: false },
        { id: "WZ-B", name: "West Zone B", pallets: 0, closed: false },
        { id: "WZ-C", name: "West Zone C", pallets: 0, closed: false },
        { id: "WZ-D", name: "West Zone D", pallets: 0, closed: false },
      ];

      function clampInt(v, fallback=0){
        const n = Number.parseInt(v, 10);
        return Number.isFinite(n) ? Math.max(0, n) : fallback;
      }

      function getStatus(zone, waterSpiderMax){
        if (zone.closed) return "CLOSED";
        if (zone.pallets === 0) return "EMPTY";
        if (zone.pallets <= waterSpiderMax) return "WATERSPIDER";
        return "PICKS_LOADING";
      }

      function statusMeta(status){
        switch(status){
          case "CLOSED": return { label: "Closed Zone", color: "var(--closed)" };
          case "EMPTY": return { label: "Empty", color: "var(--empty)" };
          case "WATERSPIDER": return { label: "WaterSpider", color: "var(--water)" };
          case "PICKS_LOADING": return { label: "Picks Loading Zone", color: "var(--picks)" };
          default: return { label: "—", color: "rgba(255,255,255,.4)" };
        }
      }

      function groupOrder(){
        return ["CLOSED", "WATERSPIDER", "EMPTY", "PICKS_LOADING"];
      }

      function App(){
        const [waterSpiderMax, setWaterSpiderMax] = React.useState(3);
        const [zones, setZones] = React.useState(DEFAULT_ZONES);
        const [lastUpdated, setLastUpdated] = React.useState(new Date());

        // Load saved
        React.useEffect(() => {
          try{
            const raw = localStorage.getItem(STORAGE_KEY);
            if(raw){
              const parsed = JSON.parse(raw);
              if(parsed?.zones) setZones(parsed.zones);
              if(Number.isFinite(parsed?.waterSpiderMax)) setWaterSpiderMax(parsed.waterSpiderMax);
              if(parsed?.lastUpdated) setLastUpdated(new Date(parsed.lastUpdated));
            }
          }catch(e){}
        }, []);

        // Live sync across tabs
        React.useEffect(() => {
          const bc = ("BroadcastChannel" in window) ? new BroadcastChannel(CHANNEL) : null;
          if(!bc) return;

          bc.onmessage = (ev) => {
            const msg = ev.data;
            if(msg?.type === "SYNC" && msg?.payload){
              setZones(msg.payload.zones);
              setWaterSpiderMax(msg.payload.waterSpiderMax);
              setLastUpdated(new Date(msg.payload.lastUpdated));
            }
          };
          return () => bc.close();
        }, []);

        function persist(nextZones, nextWaterMax){
          const payload = {
            zones: nextZones,
            waterSpiderMax: nextWaterMax,
            lastUpdated: new Date().toISOString()
          };
          setLastUpdated(new Date(payload.lastUpdated));
          localStorage.setItem(STORAGE_KEY, JSON.stringify(payload));

          if("BroadcastChannel" in window){
            const bc = new BroadcastChannel(CHANNEL);
            bc.postMessage({ type:"SYNC", payload });
            bc.close();
          }
        }

        function updateZone(id, patch){
          setZones(prev => {
            const next = prev.map(z => z.id === id ? { ...z, ...patch } : z);
            persist(next, waterSpiderMax);
            return next;
          });
        }

        function addZone(){
          const id = "WZ-" + Math.random().toString(16).slice(2,6).toUpperCase();
          const next = [...zones, { id, name: "New Zone", pallets: 0, closed: false }];
          setZones(next);
          persist(next, waterSpiderMax);
        }

        function removeZone(id){
          const next = zones.filter(z => z.id !== id);
          setZones(next);
          persist(next, waterSpiderMax);
        }

        function resetBoard(){
          const nextZones = DEFAULT_ZONES;
          const nextWS = 3;
          setZones(nextZones);
          setWaterSpiderMax(nextWS);
          persist(nextZones, nextWS);
        }

        const grouped = React.useMemo(() => {
          const buckets = { CLOSED: [], WATERSPIDER: [], EMPTY: [], PICKS_LOADING: [] };
          for(const z of zones){
            const status = getStatus(z, waterSpiderMax);
            buckets[status].push(z);
          }
          return buckets;
        }, [zones, waterSpiderMax]);

        function Column({statusKey}){
          const meta = statusMeta(statusKey);
          const list = grouped[statusKey] || [];
          return (
            <div className="col">
              <div className="colHead">
                <div className="colTitle">
                  <span style={{width:10,height:10,borderRadius:999,background:meta.color,display:"inline-block"}} />
                  {meta.label}
                </div>
                <span className="badge">{list.length}</span>
              </div>

              <div className="list">
                {list.length === 0 ? (
                  <div className="mini">No zones currently in this status.</div>
                ) : list.map(zone => <ZoneCard key={zone.id} zone={zone} />)}
              </div>
            </div>
          );
        }

        function ZoneCard({zone}){
          const status = getStatus(zone, waterSpiderMax);
          const meta = statusMeta(status);

          return (
            <div className="card">
              <div className="cardTop">
                <div>
                  <div className="zoneName">{zone.name}</div>
                  <div className="mini mono">{zone.id}</div>
                </div>

                <div className="statusChip" title="Auto-calculated status">
                  <span className="statusDot" style={{background:meta.color}} />
                  {meta.label}
                </div>
              </div>

              <div className="fields">
                <div className="field">
                  <label>Pallets remaining</label>
                  <input
                    type="number"
                    min="0"
                    value={zone.pallets}
                    onChange={(e)=>updateZone(zone.id, { pallets: clampInt(e.target.value, 0) })}
                  />
                </div>

                <div className="field">
                  <label>Zone name</label>
                  <input
                    value={zone.name}
                    onChange={(e)=>updateZone(zone.id, { name: e.target.value })}
                  />
                </div>
              </div>

              <div className="switchRow">
                <div className="hint">
                  Closed toggle overrides pallet logic
                </div>
                <div
                  className={"toggle" + (zone.closed ? " on" : "")}
                  onClick={()=>updateZone(zone.id, { closed: !zone.closed })}
                  role="switch"
                  aria-checked={zone.closed}
                  title="Toggle Closed Zone"
                >
                  <div className="knob" />
                </div>
              </div>

              <div className="row">
                <button className="btn" onClick={()=>updateZone(zone.id, { pallets: 0 })}>
                  Set Empty
                </button>
                <button className="btn" onClick={()=>removeZone(zone.id)}>
                  Remove
                </button>
              </div>
            </div>
          );
        }

        return (
          <div className="wrap">
            <div className="topbar">
              <div className="title">
                <h1>DM 1 (West Zone) — LIVE Status Board</h1>
                <div className="sub">
                  <span className="pill"><span className="dot"></span> LIVE syncing (multi-tab)</span>
                  <span className="pill">Last update: <span className="mono">{lastUpdated.toLocaleString()}</span></span>
                </div>
              </div>

              <div className="controls">
                <div className="control">
                  <label>WaterSpider threshold (max pallets)</label>
                  <input
                    type="number"
                    min="0"
                    value={waterSpiderMax}
                    onChange={(e)=>{
                      const next = clampInt(e.target.value, 0);
                      setWaterSpiderMax(next);
                      persist(zones, next);
                    }}
                  />
                  <div className="mini" style={{marginTop:8}}>
                    Example: if set to <b>{waterSpiderMax}</b>, pallets <b>1–{waterSpiderMax}</b> = WaterSpider,
                    and <b>{waterSpiderMax+1}+</b> = Picks Loading Zone.
                  </div>
                </div>

                <button className="btn" onClick={addZone}>+ Add Zone</button>
                <button className="btn" onClick={resetBoard}>Reset</button>
              </div>
            </div>

            <div className="grid">
              {groupOrder().map(k => <Column key={k} statusKey={k} />)}
            </div>

            <div className="foot">
              <b>Auto-status rules:</b>{" "}
              <span className="mono">
                Closed toggle → Closed Zone • pallets=0 → Empty • pallets 1–{waterSpiderMax} → WaterSpider • pallets {waterSpiderMax+1}+ → Picks Loading Zone
              </span>
              <br/>
              Tip: Open this file on a second monitor/tab — updates mirror instantly.
            </div>
          </div>
        );
      }

      ReactDOM.createRoot(document.getElementById("root")).render(<App />);
    </script>
  </body>
</html>
